# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=hashgram
POSTGRES_PASSWORD=change_me_strong_password_here
POSTGRES_DB=hashgram

# Connection string used by the API server and migration tool.
# When running via docker-compose, "postgres" is the service hostname.
DATABASE_URL=postgresql://hashgram:change_me_strong_password_here@postgres:5432/hashgram

# ─── API Server ────────────────────────────────────────────────────────────────
# Secret used to sign JWT tokens. Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_64_char_random_hex_string

# ─── Object / File Storage ─────────────────────────────────────────────────────
# Directory inside the api container where uploaded files are stored.
# Mapped to the `uploads_data` Docker volume — change only if you use external storage.
PRIVATE_OBJECT_DIR=/data/uploads
PUBLIC_OBJECT_SEARCH_PATHS=/data/uploads

# Leave blank if you are not using Replit Object Storage.
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
